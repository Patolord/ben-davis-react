{
	"name": "my-sveltekit-template",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "USE_LOCAL_CONVEX=true vite dev",
		"dev:hosted": "vite dev",
		"convex:dash": "docker run --rm -p 6791:6791 -e NEXT_PUBLIC_DEPLOYMENT_URL=http://127.0.0.1:3210 ghcr.io/get-convex/convex-dashboard:latest",
		"convex:gen": "CONVEX_AGENT_MODE=anonymous convex codegen",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write ."
	},
	"devDependencies": {
		"@eslint/compat": "^2.0.2",
		"@eslint/js": "^9.39.2",
		"@tailwindcss/typography": "^0.5.19",
		"@types/node": "^24",
		"eslint": "^9.39.2",
		"eslint-config-prettier": "^10.1.8",
		"globals": "^17.3.0",
		"prettier": "^3.8.1",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"tailwindcss": "^4.1.18",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.54.0",
		"vite-plugin-devtools-json": "^1.0.0"
	},
	"dependencies": {
		"@clerk/backend": "^3.2.0",
		"@clerk/clerk-js": "^6.3.0",
		"@clerk/nextjs": "^7.0.4",
		"@clerk/ui": "^1.2.1",
		"@effect/platform-node": "^4.0.0-beta.31",
		"clsx": "^2.1.1",
		"convex": "^1.33.0",
		"convex-helpers": "^0.1.114",
		"effect": "^4.0.0-beta.31",
		"next": "^16.1.6",
		"react": "^19.2.4",
		"react-dom": "^19.2.4",
		"tailwind-merge": "^3.5.0"
	}
}
